HELP.md

# Ignore unnecessary build artifacts (but NOT jar)
target/*.log
target/*.tmp

.mvn/wrapper/maven-wrapper.jar

# Allow nested target folders if needed
!**/src/main/**/target/
!**/src/test/**/target/

### STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### IntelliJ IDEA ###
.idea
*.iws
*.iml
*.ipr

### NetBeans ###
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

.vscode/

# Local environment secrets
.env
